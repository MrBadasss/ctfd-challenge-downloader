{
    "manifest_version":  3,
    "name":  "CTFd Challenge Downloader",
    "version":  "1.0.0",
    "description":  "Export CTFd challenges (name, description, metadata) and download attached files.",
    "permissions":  [
                        "activeTab",
                        "scripting",
                        "downloads",
                        "storage",
                        "unlimitedStorage"
                    ],
    "optional_host_permissions":  [
                                      "https://*/*",
                                      "http://*/*"
                                  ],
    "action":  {
                   "default_popup":  "popup.html",
                   "default_title":  "CTFd Challenge Downloader",
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "32":  "icons/icon32.png"
                                    }
               },
    "icons":  {
                  "16":  "icons/icon16.png",
                  "128":  "icons/icon128.png",
                  "48":  "icons/icon48.png",
                  "32":  "icons/icon32.png"
              },
    "background":  {
                       "service_worker":  "background.js"
                   }
}
